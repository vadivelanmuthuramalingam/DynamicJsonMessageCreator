CREATE TABLE DATA_LOAD_MASTER (
    ID NUMBER PRIMARY KEY,
    DOMAIN_NAME VARCHAR2(100) NOT NULL,
    SUB_DOMAIN_NAME VARCHAR2(100),
    MODEL_NAME VARCHAR2(100) NOT NULL,

    JOB_TYPE VARCHAR2(20) NOT NULL, -- EOD / TIME / CRON
    PERIOD_TIME VARCHAR2(100),      -- cron expression or time

    STATUS VARCHAR2(2) DEFAULT 'Y', -- Y=Ready, I=InProgress, C=Completed
    IS_ADHOC VARCHAR2(2) DEFAULT 'N',

    DATABASE_INDEX_NAME VARCHAR2(50) NOT NULL,

    CREATED_DATE DATE DEFAULT SYSDATE,
    UPDATED_DATE DATE,
	LAST_EXECUTION_TIME TIMESTAMP,
    LAST_EXECUTION_STATUS VARCHAR2(20)
	
    CONSTRAINT UK_DOMAIN_MODEL UNIQUE (DOMAIN_NAME, MODEL_NAME)
);


CREATE TABLE QUERY_MASTER (
    ID NUMBER PRIMARY KEY,
    MASTER_ID NUMBER NOT NULL,
    QUERY CLOB NOT NULL,
    QUERY_DETAILS VARCHAR2(2000),
    MODEL_NAME VARCHAR2(100),

    CONSTRAINT FK_QM_MASTER
    FOREIGN KEY (MASTER_ID)
    REFERENCES DATA_LOAD_MASTER(ID)
);



CREATE TABLE CHILD_QUERY_MASTER (
    ID NUMBER PRIMARY KEY,
    MASTER_ID NUMBER NOT NULL,
    SEQ_NO NUMBER NOT NULL,
    SUB_QUERY CLOB NOT NULL,
    QUERY_DETAILS VARCHAR2(2000),
    MODEL_NAME VARCHAR2(100),
    STATUS VARCHAR2(2) DEFAULT 'Y',

    CONSTRAINT FK_CQM_MASTER
    FOREIGN KEY (MASTER_ID)
    REFERENCES DATA_LOAD_MASTER(ID),

    CONSTRAINT UK_MASTER_SEQ UNIQUE (MASTER_ID, SEQ_NO)
);


CREATE TABLE JSON_MAPPER (
    ID NUMBER PRIMARY KEY,

    MASTER_ID NUMBER NOT NULL,
    QUERY_TYPE VARCHAR2(20) NOT NULL, -- MASTER / CHILD
    SUB_QUERY_ID NUMBER,

    JPATH VARCHAR2(500), -- $.customer.address.city

    COLUMN_NAME VARCHAR2(100),
    COLUMN_DATA_TYPE VARCHAR2(50),

    JSON_FIELD VARCHAR2(100),
    JSON_DATA_TYPE VARCHAR2(50), -- STRING, NUMBER, ARRAY, OBJECT

    IGNORE_NULL VARCHAR2(2) DEFAULT 'Y',

    IS_REFERENCE_COLUMN VARCHAR2(2) DEFAULT 'N',
    REFERENCE_KEY_NAME VARCHAR2(100),

    CONSTRAINT FK_JSON_MASTER
    FOREIGN KEY (MASTER_ID)
    REFERENCES DATA_LOAD_MASTER(ID)
);


CREATE TABLE KEY_INDEXES (
    ID NUMBER PRIMARY KEY,
    MASTER_ID NUMBER NOT NULL,
    SEQ_NO NUMBER NOT NULL,
    KEY_COMPO_PATTERN VARCHAR2(500),
    STATUS VARCHAR2(2) DEFAULT 'Y',

    CONSTRAINT FK_KEY_MASTER
    FOREIGN KEY (MASTER_ID)
    REFERENCES DATA_LOAD_MASTER(ID)
);


CREATE TABLE DATA_LOAD_JOB_AUDIT (
    AUDIT_ID NUMBER PRIMARY KEY,
    MASTER_ID NUMBER NOT NULL,

    JOB_START_TIME TIMESTAMP,
    JOB_END_TIME TIMESTAMP,

    STATUS VARCHAR2(20),  -- STARTED / SUCCESS / FAILED

    TOTAL_MASTER_RECORDS NUMBER,
    TOTAL_CHILD_RECORDS NUMBER,
    TOTAL_REDIS_KEYS NUMBER,

    ERROR_MESSAGE CLOB,

    EXECUTED_BY_POD VARCHAR2(200),
    EXECUTION_TYPE VARCHAR2(20), -- EOD / ADHOC / CRON

    CREATED_DATE TIMESTAMP DEFAULT SYSTIMESTAMP,

    CONSTRAINT FK_AUDIT_MASTER
    FOREIGN KEY (MASTER_ID)
    REFERENCES DATA_LOAD_MASTER(ID)
);




CREATE TABLE DATA_LOAD_QUERY_AUDIT (
    QUERY_AUDIT_ID NUMBER PRIMARY KEY,
    AUDIT_ID NUMBER NOT NULL,
    QUERY_TYPE VARCHAR2(20), -- MASTER / CHILD
    SUB_QUERY_ID NUMBER,

    QUERY_START_TIME TIMESTAMP,
    QUERY_END_TIME TIMESTAMP,
    STATUS VARCHAR2(20),

    RECORD_COUNT NUMBER,
    ERROR_MESSAGE CLOB,

    CONSTRAINT FK_QUERY_AUDIT
    FOREIGN KEY (AUDIT_ID)
    REFERENCES DATA_LOAD_JOB_AUDIT(AUDIT_ID)
);


